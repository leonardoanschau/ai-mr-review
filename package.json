{
  "name": "gitlabmcp-anschauti",
  "displayName": "GitlabMCP-AnschauTI",
  "description": "GitLab productivity tools - Create issues, list projects, and templates using GitHub Copilot",
  "version": "1.1.1",
  "publisher": "AnschauTI",
  "repository": {
    "type": "git",
    "url": "https://github.com/anschauti/gitlab-mcp-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "gitlab",
    "issues",
    "user stories",
    "mcp",
    "copilot",
    "project management",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitlabmcp.configure",
        "title": "Configure Server (Secure)",
        "category": "GitLab MCP AnschauTI",
        "icon": "$(gear)"
      },
      {
        "command": "gitlabmcp.showConfiguration",
        "title": "Show Configuration",
        "category": "GitLab MCP AnschauTI",
        "icon": "$(info)"
      },
      {
        "command": "gitlabmcp.clearConfiguration",
        "title": "Clear Configuration",
        "category": "GitLab MCP AnschauTI",
        "icon": "$(trash)"
      },
      {
        "command": "gitlabmcp.createIssue",
        "title": "Create GitLab Issue",
        "category": "GitLab MCP AnschauTI"
      },
      {
        "command": "gitlabmcp.listProjects",
        "title": "List GitLab Projects",
        "category": "GitLab MCP AnschauTI"
      },
      {
        "command": "gitlabmcp.showTemplate",
        "title": "Show Issue Template",
        "category": "GitLab MCP AnschauTI"
      }
    ],
    "configuration": {
      "title": "GitLab MCP AnschauTI",
      "properties": {
        "gitlabmcp.gitlab.url": {
          "type": "string",
          "default": "http://gitlab.dimed.com.br/api/v4",
          "description": "URL da API do GitLab",
          "order": 1
        },
        "gitlabmcp.gitlab.defaultGroup": {
          "type": "string",
          "default": "",
          "description": "Grupo padrão do GitLab (com subgrupos recursivos)",
          "order": 2
        },
        "gitlabmcp.gitlab.defaultAssignee": {
          "type": "string",
          "default": "",
          "description": "Username padrão do assignee (vazio = você)",
          "order": 3
        },
        "gitlabmcp.mcp.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Caminho para o executável Python",
          "order": 4
        },
        "gitlabmcp.mcp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Caminho para o crm_mcp_server.py (vazio = detecta automaticamente)",
          "order": 5
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "gitlabmcp.configure"
        },
        {
          "command": "gitlabmcp.showConfiguration"
        },
        {
          "command": "gitlabmcp.clearConfiguration"
        },
        {
          "command": "gitlabmcp.createIssue"
        },
        {
          "command": "gitlabmcp.listProjects"
        },
        {
          "command": "gitlabmcp.showTemplate"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run compile-server",
    "compile": "tsc -p ./",
    "compile-server": "cd server && npm install && npm run build",
    "watch": "tsc -watch -p ./",
    "watch-server": "cd server && npm run watch",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies --allow-missing-repository",
    "publish": "vsce publish",
    "clean": "rm -rf out server/dist server/node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "eslint": "^8.x",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {}
}
